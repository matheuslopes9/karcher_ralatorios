# ══════════════════════════════════
# AUTH / JWT
# ══════════════════════════════════
JWT_SECRET=change-me-to-random-string-minimum-64-characters-long-please-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
BCRYPT_COST=12

# ══════════════════════════════════
# USUÁRIO MASTER (seed inicial)
# ══════════════════════════════════
MASTER_USERNAME=admin
MASTER_PASSWORD=UCT3chn0l0gy!@
MASTER_EMAIL=matheus.lopes@uctechnology.com.br
MASTER_NAME=UC Technology Admin

# ══════════════════════════════════
# API BACKEND
# ══════════════════════════════════
API_PORT=8080
API_CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=15m
RATE_LIMIT_LOGIN_BLOCK=15m

# ══════════════════════════════════
# ANÁLISE
# ══════════════════════════════════
ANALYSIS_INTERVAL=5m
SNAPSHOT_RETENTION_DAYS=365

# ══════════════════════════════════
# EXPORTAÇÃO
# ══════════════════════════════════
PDF_COMPANY_NAME=UC Technology / Kärcher
PDF_COMPANY_LOGO_URL=
EXPORT_MAX_ROWS=50000
EXPORT_TEMP_DIR=/tmp/exports

# ══════════════════════════════════
# FRONTEND
# ══════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=Kärcher Analytics

# ══════════════════════════════════
# AMBIENTE
# ══════════════════════════════════
ENVIRONMENT=development
