# ══════════════════════════════════
# API BACKEND
# ══════════════════════════════════
API_PORT=8080
API_CORS_ORIGINS=https://analytics.karcher.uctechnology.com.br
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=15m
RATE_LIMIT_LOGIN_BLOCK=15m

# ══════════════════════════════════
# ANÁLISE
# ══════════════════════════════════
ANALYSIS_INTERVAL=5m
SNAPSHOT_RETENTION_DAYS=365

# ══════════════════════════════════
# EXPORTAÇÃO
# ══════════════════════════════════
PDF_COMPANY_NAME=UC Technology / Kärcher
PDF_COMPANY_LOGO_URL=
EXPORT_MAX_ROWS=50000
EXPORT_TEMP_DIR=/tmp/exports

# ══════════════════════════════════
# AMBIENTE
# ══════════════════════════════════
ENVIRONMENT=production
LOG_LEVEL=info
TZ=America/Sao_Paulo
