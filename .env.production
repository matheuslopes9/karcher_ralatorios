# ══════════════════════════════════
# AUTH / JWT
# ⚠️ MUDE O JWT_SECRET PARA UMA STRING ALEATÓRIA DE 64+ CARACTERES
# ══════════════════════════════════
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_MINIMUM_STRING_PLEASE_GENERATE_ONE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
